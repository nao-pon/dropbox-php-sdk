{
    "name": "nao-pon/dropbox-php-sdk",
    "description": "Minimal maintenance fork of an unofficial Dropbox PHP SDK for modern PHP compatibility",
    "keywords": [
        "dropbox",
        "sdk",
        "api",
        "client",
        "php",
        "elfinder"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Kunal Varma",
            "email": "kunalvarma05@gmail.com"
        },
        {
            "name": "nao-pon",
            "homepage": "https://github.com/nao-pon"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/collections": "^8.0|^9.0|^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Kunnu\\Dropbox\\": "src/Dropbox"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}